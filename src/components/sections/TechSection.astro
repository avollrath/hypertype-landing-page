---
import { Image } from 'astro:assets';
import Button from '@/components/ui/Button.astro';
import menuScreenshot from '@/assets/images/menu-screenshot.png';

interface Tool {
  icon: string;
  label: string;
}

interface Props {
  tools?: Tool[];
  gameUrl?: string;
}

const {
  tools = [
    { icon: '<>', label: 'Godot 4 & GDScript' },
    { icon: '⊡', label: 'Talo Game Services' },
    { icon: '◎', label: 'Optimized for Web Play' }
  ],
  gameUrl = 'https://avollrath.github.io/HyperType/'
} = Astro.props;
---

<section class="tech" id="about" aria-labelledby="tech-title" data-reveal>
  <div class="container tech-grid">
    <figure class="menu-panel neon-panel neon-panel-cyan">
      <Image
        src={menuScreenshot}
        alt="HyperType main menu with synthwave perspective grid background and magenta-bordered login panel"
        loading="lazy"
        width={1261}
        height={720}
      />
      <figcaption>HyperType</figcaption>
    </figure>
    <div class="tech-copy">
      <h2 id="tech-title" class="text-glow-magenta">BUILT WITH MODERN TOOLS</h2>
      <ul>
        {tools.map((tool) => (
          <li><span>{tool.icon}</span>{tool.label}</li>
        ))}
      </ul>
      <p>HyperType runs entirely in your browser. No installation. No downloads. Just type.</p>
      <Button href={gameUrl} label="PLAY IN BROWSER" variant="outline">PLAY IN BROWSER →</Button>
    </div>
  </div>
</section>

<style>
  .tech {
    padding: var(--spacing-section-sm) 0;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.84fr);
    gap: 70px;
    align-items: center;
  }

  .menu-panel {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    margin: 0;
  }

  img {
    display: block;
    width: 100%;
    height: auto;
  }

  figcaption {
    position: absolute;
    top: 12px;
    right: 12px;
    border: 1px solid rgba(255, 0, 184, 0.48);
    background: rgba(3, 6, 18, 0.74);
    color: var(--color-magenta);
    padding: 6px 10px;
    font-size: 0.72rem;
  }

  h2 {
    color: var(--color-magenta);
    font-size: clamp(1.7rem, 3.6vw, 2rem);
    line-height: 1.25;
  }

  ul {
    display: grid;
    gap: 16px;
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: flex;
    gap: 12px;
    align-items: center;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  li span {
    width: 28px;
    color: var(--color-cyan);
    text-shadow: 0 0 14px rgba(0, 214, 255, 0.7);
  }

  p {
    margin: 26px 0 24px;
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .tech-grid {
      grid-template-columns: 1fr;
      gap: 34px;
    }
  }
</style>
