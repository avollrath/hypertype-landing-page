---
import StatCounter from '@/components/ui/StatCounter.astro';

interface Stat {
  label: string;
  value: number;
  suffix?: string;
}

interface Props {
  stats?: Stat[];
}

const {
  stats = [
    { label: 'Total Words', value: 0 },
    { label: 'Playtime (S)', value: 0 },
    { label: 'Longest Streak', value: 0 },
    { label: 'Accuracy', value: 0, suffix: '%' },
    { label: 'Bosses Defeated', value: 0 },
    { label: 'HS Level', value: 1 }
  ]
} = Astro.props;
---

<section class="stats-section" aria-labelledby="stats-title" data-reveal data-stat-section>
  <div class="container">
    <div class="stats-panel neon-panel neon-panel-cyan">
      <h2 id="stats-title" class="text-glow-cyan">TRACK YOUR PROGRESS</h2>
      <div class="stats-grid">
        {stats.map((stat) => <StatCounter label={stat.label} value={stat.value} suffix={stat.suffix} />)}
      </div>
      <p>Stats sync across sessions when you create a free account.</p>
    </div>
  </div>
</section>

<style>
  .stats-section {
    padding: var(--spacing-section-sm) 0;
  }

  .stats-panel {
    width: min(100%, 940px);
    margin-inline: auto;
    border-top: 3px solid var(--color-cyan);
    padding: 46px 38px 30px;
  }

  h2 {
    color: var(--color-cyan);
    font-size: clamp(1.55rem, 3vw, 1.9rem);
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    margin-top: 34px;
  }

  .stats-grid :global(.stat-counter:not(:last-child)) {
    border-right: 1px solid rgba(255, 0, 184, 0.22);
  }

  p {
    margin-top: 28px;
    text-align: center;
    font-size: 0.76rem;
  }

  @media (max-width: 820px) {
    .stats-grid { grid-template-columns: repeat(3, 1fr); row-gap: 24px; }
    .stats-grid :global(.stat-counter:not(:last-child)) { border-right: 0; }
  }

  @media (max-width: 520px) {
    .stats-panel { padding-inline: 18px; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
