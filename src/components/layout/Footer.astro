---
interface FooterLink {
  label: string;
  href: string;
}

interface Props {
  links?: FooterLink[];
}

const {
  links = [
    { label: 'GitHub', href: 'https://github.com/avollrath/HyperType' },
    { label: 'Privacy_Policy', href: '#' },
    { label: 'Terms', href: '#' },
    { label: 'Credits', href: '#' }
  ]
} = Astro.props;
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="footer-brand text-glow-magenta" href="#main-content">HYPERTYPE</a>
      <p>© 2026 HYPERTYPE_SYSTEMS.</p>
      <p>by <a href="https://www.vollrath.dev" class="author-link">André Vollrath</a></p>
    </div>
    <nav class="footer-links" aria-label="Footer navigation">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <div class="social-links" aria-label="Social links">
      <a href="https://github.com/avollrath/HyperType" aria-label="HyperType GitHub repository">GH</a>
      <a href="https://avollrath.github.io/HyperType/" aria-label="Play HyperType">&lt;/&gt;</a>
    </div>
  </div>
  <p class="footer-line">avollrath.github.io/HyperType</p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(255, 0, 184, 0.3);
    background: var(--color-bg-deep);
    padding: 42px 48px 24px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: start;
    width: min(100%, var(--content-max));
    margin-inline: auto;
  }

  .footer-brand {
    color: var(--color-magenta);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  p {
    margin-top: 6px;
    font-size: 0.72rem;
  }

  .author-link {
    color: var(--color-muted);
    transition: color 150ms ease, text-shadow 150ms ease;
  }

  .author-link:hover {
    color: var(--color-magenta);
    text-shadow: 0 0 14px rgba(255, 0, 184, 0.65);
  }

  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a,
  .social-links a {
    color: var(--color-muted);
    font-size: 0.76rem;
    transition: color 150ms ease, text-shadow 150ms ease;
  }

  .footer-links a:hover,
  .social-links a:hover {
    color: var(--color-magenta);
    text-shadow: 0 0 14px rgba(255, 0, 184, 0.65);
  }

  .social-links {
    display: flex;
    justify-content: flex-end;
    gap: 16px;
  }

  .footer-line {
    margin-top: 30px;
    text-align: center;
  }

  @media (max-width: 767px) {
    .site-footer { padding-inline: 24px; }
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .social-links { justify-content: center; }
  }
</style>
